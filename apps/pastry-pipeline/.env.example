# ─── Required ───────────────────────────────────────────────
# Anthropic — prompt generation, voice fingerprinting (BrandBrain)
ANTHROPIC_API_KEY=sk-ant-...

# ─── Demo / cost guardrail ──────────────────────────────────
# Set to 1 to skip live Veo/ElevenLabs calls and use stock fallbacks.
# Recommended for prospect demos so you don't burn credits live.
STUDIO_DEMO_MODE=1

# ─── Veo 3 (Vertex AI) — optional, only when STUDIO_DEMO_MODE=0 ──
GCP_PROJECT_ID=
VEO_LOCATION=us-central1
VEO_MODEL=veo-3.0-generate-preview
GOOGLE_APPLICATION_CREDENTIALS=

# ─── Veo 3 Fast (Gemini API free tier) — alternative path ────
GEMINI_API_KEY=
GEMINI_PROJECT_NUMBER=
VEO_GEMINI_MODEL=veo-3.0-fast-generate-preview

# ─── ElevenLabs (creator-POV narration) ──────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_turbo_v2_5

# ─── ffmpeg (mux narration onto video) ───────────────────────
# Path to ffmpeg binary. Railway Nixpacks: install via nixpacks.toml.
FFMPEG_PATH=ffmpeg

# ─── Apify (Instagram scrape for BrandBrain) ─────────────────
APIFY_API_TOKEN=

# Railway sets PORT automatically; locally defaults to 3002
# PORT=3002
